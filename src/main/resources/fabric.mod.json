{
	"schemaVersion": 1,
	"id": "origin-buildcrafts-own",
	"version": "${version}",
	"name": "Origin: BuildCraft's own",
	"description": "This is an Origins Addon mod, current it add one Origin. The Giant! A realistic interpretation of a player scaled up to twice their normal size! \nThis mod was made with substantial use of AI",
	"authors": [
		"PolloDelMuerteJr"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/origin-buildcrafts-own/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"name.modid.OriginBuildCraftSOwn"
		],
		"client": [
			"name.modid.client.OriginBuildCraftSOwnClient"
		]
	},
	"mixins": [
		"origin-buildcrafts-own.mixins.json",
		{
			"config": "origin-buildcrafts-own.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.20.2",
		"java": ">=17",
